<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      throwConfigExceptions="true">

  <targets>
    <!-- Файловый лог: ротация по дате, хранить 30 дней -->
    <target xsi:type="File"
            name="fileLog"
            fileName="${basedir}/logs/greenstock-${shortdate}.log"
            layout="${longdate} | ${level:uppercase=true:padding=-5} | ${logger:shortName=true} | ${message} ${exception:format=tostring}"
            archiveEvery="Day"
            archiveNumbering="Date"
            maxArchiveDays="30"
            keepFileOpen="false"
            encoding="utf-8" />

    <!-- Консольный лог (удобно при отладке в VS) -->
    <target xsi:type="Console"
            name="consoleLog"
            layout="${time} | ${level:uppercase=true:padding=-5} | ${logger:shortName=true} | ${message} ${exception:format=message}" />
  </targets>

  <rules>
    <!-- Все уровни (Trace и выше) → в файл -->
    <logger name="*" minlevel="Trace" writeTo="fileLog" />
    <!-- Debug и выше → в консоль -->
    <logger name="*" minlevel="Debug" writeTo="consoleLog" />
  </rules>
</nlog>
